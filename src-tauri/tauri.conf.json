{
    "productName": "Galleria Expressive",
    "version": "0.13.0",
    "identifier": "com.galleria.app",
    "build": {
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build",
        "devUrl": "http://localhost:1420",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Galleria Expressive",
                "width": 1200,
                "height": 800,
                "minWidth": 800,
                "minHeight": 600,
                "resizable": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost tauri: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'",
            "assetProtocol": {
                "enable": true,
                "scope": [
                    "$APP_CACHE_DIR/**",
                    "$APP_DATA_DIR/**",
                    "$HOME/.cache/galleria-expressive/**",
                    "$HOME/Pictures/**",
                    "$HOME/Downloads/**",
                    "$HOME/Documents/**",
                    "$HOME/DCIM/**"
                ]
            },
            "capabilities": [
                "main-capability"
            ]
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "category": "Photography",
        "shortDescription": "Photo and media viewer with Liquid Glass UI",
        "longDescription": "View and organize photos and media. Select a directory, scan and categorize, search with natural language."
    },
    "plugins": {
        "updater": {
            "endpoints": [
                "https://github.com/ARYAN007H/Galleria-Expressive/releases/latest/download/latest.json"
            ],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY1QzhGQ0JGNDI5QTBGNEYKUldSUEQ1cEN2L3pJOVlsRFdzaHlIVUlEUzMrOWJJdWVZcVAzTUgvS2ZzeWJhcDRIaFd6djhBZWgK"
        }
    }
}